<!DOCTYPE html>
<html>
    <head>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"> <!--widht=device-width:端末の幅　initial-scale:初期倍率-->
        <title>Friend</title>
        <link rel="stylesheet" href="friend.css" >
    </head>
    <body>
        <h3>フレンドモード</h3>
        <% if (friendMessage.length > 0) { %>
                    <p style="color: red;"><%= friendMessage %></p>
                <% } %>
        <form id = "friend" action="/friend" method="post">
            <div>
                <input type="radio" name="room" value="createRoom" id="radio1" >
                <label class="radio-button" for="radio1">部屋を作る</label>
                    
                <input type="radio" name="room" value="joinRoom" id="radio2">
                <label class="radio-button" for="radio2">部屋に参加する</label>
                    
                <input type="text" id="roomID" name="roomID" placeholder="ルームID">
            </div>
            <button>入室</button>
        </form>

        <script>
        const roomID = document.getElementById('roomID');
                
                friend.addEventListener('submit', (e) => { //nameformがsubmitされたとき
                    e.preventDefault();
                    let checkValue = nameForm.elements['room'].value;//createRoom or joinRoom
                    localStorage.setItem('roomSelect', checkValue);
                    
                        if(checkValue){ //ラジオボックスが選択されていたら
                            if(checkValue === 'createRoom'){
                                //socket.emit('create room', checkValue); //create roomイベントを送信
                                
                                window.location.href = 'chat.html';
                            }else if(checkValue === 'joinRoom'){
                                if(roomID.value){ //roomIDが入力されていたら
                                    //socket.emit('join room', roomID.value);
                                    //socket.emit('join room message', username.value);
                                    window.location.href = 'chat.html';

                                }else{
                                    alert('ルームIDを入力してください');
                                }
                            }
                        }else{
                            alert('選択してください');
                        }
                    })

        
    </body>
</html>